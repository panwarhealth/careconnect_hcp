# =======================================================================
# Local dev values — copy this file to `.env` and customise for yourself.
# `.env` is gitignored. Do NOT put production credentials in either file.
#
# Production credentials live in the prod server's wp-config.php (fallback
# constants) or in Azure App Service configuration (staging) — never here.
# =======================================================================

# --- Database (used by the `db` service AND read by wp-config.php) ------
WORDPRESS_DB_NAME=hcp_care
WORDPRESS_DB_USER=hcp_care
WORDPRESS_DB_PASSWORD=devpass
WORDPRESS_DB_HOST=db:3306
WORDPRESS_TABLE_PREFIX=tbstwp_

# MySQL root password — used only for `docker compose exec db mysql -uroot`
MYSQL_ROOT_PASSWORD=rootdevpass

# --- Site URL ----------------------------------------------------------
# The port the wordpress service is published on. If you change this,
# also re-run the wp-cli search-replace step documented in README.md.
WORDPRESS_PORT=8080

# --- Debugging ---------------------------------------------------------
# WP_DEBUG=true enables notice/warning output to /wp-content/debug.log.
# WP_DEBUG_DISPLAY=false prevents leaking to the browser.
# SCRIPT_DEBUG=true loads unminified JS/CSS — keep this on for hot-edit work.
WORDPRESS_DEBUG=1
WORDPRESS_DEBUG_DISPLAY=0
WORDPRESS_SCRIPT_DEBUG=1

# --- AHPRA PIEWS API ---------------------------------------------------
# Credentials for AHPRA's Practitioner Information Exchange Web Service
# (practitioner registration lookup — gatekeeping for LMS access).
# Values are NOT checked in anywhere; grab them from the .env of another
# dev machine, or from prod's wp-config.php (putenv lines), or request
# from AHPRA directly.
AHPRA_PIEWS_USER=
AHPRA_PIEWS_PASSWORD=

# --- Authentication salts ----------------------------------------------
# Generate fresh throwaway values for local dev:
#   curl -s https://api.wordpress.org/secret-key/1.1/salt/
# Then paste the eight lines below (AUTH_KEY through NONCE_SALT).
# These never leave your machine; they do NOT need to match production.
WORDPRESS_AUTH_KEY=replace-me
WORDPRESS_SECURE_AUTH_KEY=replace-me
WORDPRESS_LOGGED_IN_KEY=replace-me
WORDPRESS_NONCE_KEY=replace-me
WORDPRESS_AUTH_SALT=replace-me
WORDPRESS_SECURE_AUTH_SALT=replace-me
WORDPRESS_LOGGED_IN_SALT=replace-me
WORDPRESS_NONCE_SALT=replace-me
